#include <stdio.h>
float Discount(float p, int t) 
{
    float final;
    if (t == 1) 
	{
		final = p * 0.95;
	}
    else if (t == 2)
	{
		final = p * 0.90;
	} 
    else if (t == 3)
	{
		final = p * 0.80;
	} 
    else if (t == 4)
	{
		final = p * 0.70;
	} 
    else
	{
    	final = p;
	} 
    return final;
}
void output(float o, float d) 
{
    float delivery = 0;
    if (d < 2000)
	{
		delivery = 150;
	} 
    printf("\n--- Bill ---\n");
    printf("Original: %.2f\nDiscounted: %.2f\n", o, d);
    printf("Delivery: %.2f\nTotal: %.2f\n", delivery, d + delivery);
}
int main() 
{
    float p1; 
	int t1;
    printf("price: "); 
	scanf("%f", &p1);
    printf("enter tier : "); scanf("%d", &t1);
    float d1 = Discount(p1, t1);
    output(p1, d1);
    
    return 0;
}

