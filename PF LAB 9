#include <stdio.h>
int main()
{
    int arr[6] = {45, 50, 60, 30, 55, 40};
    int *p = arr;
    int i, highest;

    printf("Original Marks:\n");
    for(i = 0; i < 6; i++)
    {
        printf("%d ", *(p + i));
    }


    highest = *(p + 0);
    for(i = 1; i < 6; i++)
    {
        if(*(p + i) > highest)
        {
            highest = *(p + i);
        }
    }


    for(i = 0; i < 6; i++)
    {
        *(p + i) = (int)(((float)*(p + i) / highest) * 100);
    }

    printf("\n\nScaled Marks:\n");
    for(i = 0; i < 6; i++)
    {
        printf("%d ", *(p + i));
    }

    return 0;
}
