#include <stdio.h>

float toMegajoules(float kwh)
{
    return kwh * 3.6;
}

float toBTU(float kwh)
{
    return kwh * 3412.14;
}

float toCalories(float kwh)
{
    return kwh * 859845;
}

int main()
{
    float kwh;
    float mj, btu, cal;

    printf("Enter energy in kWh: ");
    scanf("%f", &kwh);

   
    mj = toMegajoules(kwh);
    btu = toBTU(kwh);
    cal = toCalories(kwh);

    printf("\n--- Conversion Report ---\n");
    printf("Energy in kWh: %.2f\n", kwh);
    printf("Megajoules: %.2f MJ\n", mj);
    printf("BTU: %.2f\n", btu);
    printf("Calories: %.2f\n", cal);

    printf("\nDirect call (MJ): %.2f MJ\n", toMegajoules(kwh));

    return 0;
}







