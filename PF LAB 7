#include <stdio.h>
int main() 
{
    int arr[10], search, count = 0;

    printf("Enter 10 numbers:\n");

    for(int i=0; i<10; i++) 
    {
        scanf("%d", &arr[i]);
    }

    printf("Enter number to search: ");
    scanf("%d", &search);

    for(int i=0; i<10; i++) 
    {
        if(arr[i]==search)
        {
            count++;
        }
    }

    if(count>0) 
    {
        printf("The number %d occurred %d times", search, count);
    }
    else 
    {
        printf("Number not found");
    }

    return 0;
}

