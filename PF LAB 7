#include<stdio.h>
int main()
{
    char str[100];
    int i=0;

    printf("Enter a sentence: ");
    scanf("%[^\n]",str);

    for(i=0; str[i]!='\0'; i++)
    {
        if(str[i]>='a' && str[i]<='z')
        {
            str[i]= str[i]-32;
        }
        else if(str[i]>='A' && str[i]<='Z')
        {
            str[i]=str[i]+32;
        }
    }

    printf("message: %s",str);

    return 0;
}

