#include<stdio.h>
int main()
{
    int pass[10], fail[10];
    int mark, i;
    int p=0, f=0;
    int sumPass=0, sumFail=0;

    printf("Enter quiz marks:\n");

    for(i=0; i<10; i++)
    {
        scanf("%d",&mark);

        if(mark==-1)
            break;

        if(mark>=5 && mark<=10)
        {
            pass[p]=mark;
            sumPass=sumPass+mark;
            p++;
        }
        else if(mark>=0 && mark<5)
        {
            fail[f]=mark;
            sumFail=sumFail+mark;
            f++;
        }
    }

    printf("\nPass Students Marks:\n");
    for(i=0; i<p; i++)
        printf("%d ",pass[i]);

    if(p>0)
        printf("\nAverage Pass Marks: %.2f",(float)sumPass/p);

    printf("\n\nFail Students Marks:\n");
    for(i=0; i<f; i++)
        printf("%d ",fail[i]);

    if(f>0)
        printf("\nAverage Fail Marks: %.2f",(float)sumFail/f);

    return 0;
}

