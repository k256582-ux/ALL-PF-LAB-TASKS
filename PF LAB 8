#include<stdio.h>
int main()
{
    int a1[9];
    int a[3][3];
    int i,j,k=0;

    printf("Enter 9 elements:\n");

    for(i=0;i<9;i++)
    {
        scanf("%d",&a1[i]);
    }

    for(i=0;i<3;i++)
    {
        for(j=i;j<=i+6;j=j+3)
        {
            a[i][k]=a1[j];
            k++;
            if(k==3)
                k=0;
        }
    }

 
    printf("Matrix:\n");
    for(i=0;i<3;i++)
    {
        for(j=0;j<3;j++)
        {
            printf("%d ",a[i][j]);
        }
        printf("\n");
    }

   
    printf("Transpose:\n");
    for(i=0;i<3;i++)
    {
        for(j=0;j<3;j++)
        {
            printf("%d ",a[j][i]);
        }
        printf("\n");
    }

    
    int det;

    det = a[0][0]*(a[1][1]*a[2][2]-a[1][2]*a[2][1])
        - a[0][1]*(a[1][0]*a[2][2]-a[1][2]*a[2][0])
        + a[0][2]*(a[1][0]*a[2][1]-a[1][1]*a[2][0]);

    printf("Determinant = %d\n",det);

    return 0;
}






