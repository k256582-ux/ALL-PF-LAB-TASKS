#include<stdio.h>
int main()
{
    int a[5][5];
    int r,c,i,j;

    printf("Enter rows and columns:\n");
    scanf("%d%d",&r,&c);

    printf("Enter matrix:\n");
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }

    if(r==c)
        printf("Square Matrix\n");
    else
        printf("Rectangular Matrix\n");


    int zero=1;
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            if(a[i][j]!=0)
                zero=0;
        }
    }
    if(zero==1)
        printf("Zero Matrix\n");

    if(r==1)
        printf("Row Matrix\n");

    if(c==1)
        printf("Column Matrix\n");

    if(r==c)
    {
        int identity=1,diagonal=1,scalar=1;
        int upper=1,lower=1,symmetric=1,skew=1;

        for(i=0;i<r;i++)
        {
            for(j=0;j<c;j++)
            {
                if(i==j && a[i][j]!=1)
                {
                	identity=0;
				}
                    
                if(i!=j && a[i][j]!=0)
                {
                	identity=0;
				}
                    

                if(i!=j && a[i][j]!=0)
                {
                	diagonal=0;
				}
                    

                if(i!=j && a[i][j]!=0)
                {
                	scalar=0;
				}
                    
                if(i==j && a[i][j]!=a[0][0])
                {
                	scalar=0;
				}
                    

                if(i>j && a[i][j]!=0)
                {
                	upper=0;
				}
                    

                if(i<j && a[i][j]!=0)
                {
                	lower=0;
				}
                    

                if(a[i][j]!=a[j][i])
                {
                	symmetric=0;
				}
                    

                if(a[i][j]!=-a[j][i])
                {
                	skew=0;
				}
                    
            }
        }

        if(identity==1)
            printf("Identity Matrix\n");

        if(diagonal==1)
            printf("Diagonal Matrix\n");

        if(scalar==1)
            printf("Scalar Matrix\n");

        if(upper==1)
        {
        	printf("Upper Triangular Matrix\n");
		}
            

        if(lower==1)
        {
        	printf("Lower Triangular Matrix\n");
		}
            

        if(symmetric==1)
        {
        	printf("Symmetric Matrix\n");
		}
            

        if(skew==1)
        {
        	printf("Skew Symmetric Matrix\n");
		}
            

       
        if(r==3)
        {
            int det;

            det = a[0][0]*(a[1][1]*a[2][2]-a[1][2]*a[2][1])- a[0][1]*(a[1][0]*a[2][2]-a[1][2]*a[2][0])+ a[0][2]*(a[1][0]*a[2][1]-a[1][1]*a[2][0]);

            if(det==0)
            {
            	printf("Singular Matrix\n");
            else
                printf("Non-Singular Matrix\n");
			}
                
        }
    }

    return 0;
}










