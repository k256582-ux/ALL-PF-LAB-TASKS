#include <stdio.h>
int main() 
{
    int rating;
    int excellent = 0, satisfactory = 0, needsImprovement = 0;

    printf("Enter employee rating : ");
    scanf("%d", &rating);

    while (rating != -1) 
	{
        if (rating >= 85) {
            excellent++;
        }
        if (rating < 85 && rating >= 60) {
            satisfactory++;
        }
        if (rating < 60) {
            needsImprovement++;
        }

        printf("Enter employee rating : ");
        scanf("%d", &rating);
    }

    printf("Excellent: %d\n", excellent);
    printf("Satisfactory: %d\n", satisfactory);
    printf("Needs Improvement: %d\n", needsImprovement);

    return 0;
}

