int main() 
{
    int spaces = 50;
    int Entry;

    while (spaces > 0) 
	{
        printf("Car arrived (1 = park, 0 = stop): ");
        scanf("%d", &Entry);

        if (Entry == 0) 
		break;

        spaces--;
        printf("Remaining spaces: %d\n", spaces);

        if (spaces==0)
		{
        	printf("Parking lot full!\n");
		} 
    }

    printf("Parking closed.\n");
    return 0;
}
