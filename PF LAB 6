#include <stdio.h>
int main() 
{
    int units;
	float average;
    int totalUnits=0;
    int days=0;
    

    printf("Enter daily units consumed: ");
    scanf("%d", &units);

    while (units!= -999) 
	{
        totalUnits=totalUnits+units;
        days++;
        printf("Enter daily units consumed: ");
        scanf("%d", &units);
    }

    if (days>0) 
	{
        average= (float)totalUnits/days;
        printf("Average daily consumption: %.2f units\n", average);
    } 
	else 
	{
        printf("No data entered\n");
    }

    return 0;
}

